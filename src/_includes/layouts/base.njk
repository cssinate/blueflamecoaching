<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — Blue Flame Coaching</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <a href="#main-content" class="skip-link">Skip to main content</a>

  <header class="site-header">
    <div class="site-header__inner">
      <a href="/" class="site-header__brand" aria-label="Blue Flame Coaching home">
        Blue Flame Coaching
      </a>
      <nav aria-label="Primary">
        <ul class="site-nav">
          <li><a href="/"{% if page.url == "/" %} aria-current="page"{% endif %}>Home</a></li>
          <li><a href="/about/"{% if page.url == "/about/" %} aria-current="page"{% endif %}>About</a></li>
          <li><a href="/contact/"{% if page.url == "/contact/" %} aria-current="page"{% endif %}>Contact</a></li>
          <li>
            <a href="https://www.linkedin.com/" target="_blank" rel="noopener noreferrer" class="site-nav--linkedin">
              <svg aria-hidden="true" viewBox="0 0 24 24" fill="currentColor" height="18" width="18">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              <span>LinkedIn</span>
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </header>

  <main id="main-content" tabindex="-1">
    {{ content | safe }}
  </main>

</body>
</html>
